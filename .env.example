# MineralScope — API Keys for Free Data Sources
# Copy to .env.local and fill in your keys

# ── No Auth Required (leave blank) ──────────────────────────
# Federal Register API — no key needed
# GDELT Project API — no key needed
# SEC EDGAR — no key needed (User-Agent set in code)
# Consolidated Screening List (trade.gov) — no key needed
# USASpending.gov — no key needed

# ── Free Registration Required ──────────────────────────────
# UN Comtrade: Register at https://comtradedeveloper.un.org/
COMTRADE_API_KEY=

# NASA FIRMS: Register at https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=

# EIA: Register at https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# Global Fishing Watch: Register at https://globalfishingwatch.org/our-apis/
GFW_API_TOKEN=

# aisstream.io: Register at https://aisstream.io/ (GitHub login)
AISSTREAM_API_KEY=
